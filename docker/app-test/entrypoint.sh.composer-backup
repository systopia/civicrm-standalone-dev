#!/bin/bash
set -euo pipefail

CIVICRM_TEST_DIR=/opt/civicrm-test
DB_HOST=${DB_HOST:-db}
DB_NAME=${DB_NAME:-civicrm_test}
DB_USER=${DB_USER:-civicrm}
DB_PASS=${DB_PASS:-civicrm}
DB_ROOT_USER=${DB_ROOT_USER:-root}
DB_ROOT_PASS=${DB_ROOT_PASS:-root}
CIVICRM_COMPONENTS=${CIVICRM_COMPONENTS:-CiviReport}
DATABASE_URL="mysql://${DB_USER}:${DB_PASS}@${DB_HOST}:3306/${DB_NAME}?new_link=true"

log() { printf '==> %s\n' "$*"; }

wait_for_db() {
  for _ in $(seq 1 60); do
    if mariadb -h "$DB_HOST" -u"$DB_USER" -p"$DB_PASS" -e 'SELECT 1' >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
  done
  echo "DB $DB_HOST not reachable" >&2
  exit 1
}

is_installed() {
  [ -f "$CIVICRM_TEST_DIR/civicrm.standalone.php" ]
}

install_civicrm() {
  log "Resetting DB $DB_NAME"
  mariadb -h "$DB_HOST" -u"$DB_ROOT_USER" -p"$DB_ROOT_PASS" <<SQL
DROP DATABASE IF EXISTS \`$DB_NAME\`;
CREATE DATABASE \`$DB_NAME\` CHARACTER SET utf8mb4;
GRANT ALL ON \`$DB_NAME\`.* TO '$DB_USER'@'%';
GRANT SUPER ON *.* TO '$DB_USER'@'%';
FLUSH PRIVILEGES;
SQL

  log "Cloning civicrm-standalone"
  rm -rf /tmp/standalone
  git clone https://github.com/civicrm/civicrm-standalone.git /tmp/standalone

  # Do NOT carry over the repo's ext/ directory — otherwise the ext bind
  # mount would write repo defaults into the real civicrm-extensions/.
  find /tmp/standalone -mindepth 1 -maxdepth 1 -not -name ext \
    -exec mv {} "$CIVICRM_TEST_DIR/" \;
  rm -rf /tmp/standalone

  cd "$CIVICRM_TEST_DIR"
  log "composer install"
  composer install --no-progress --optimize-autoloader

  log "cv core:install"
  export PATH="$CIVICRM_TEST_DIR/vendor/bin:$PATH"
  cv core:install -f --db="$DATABASE_URL" --comp="$CIVICRM_COMPONENTS"
}

ensure_test_db_dsn() {
  cd "$CIVICRM_TEST_DIR"
  [ -f /root/.cv.json ] || cv vars:fill >/dev/null 2>&1 || true
  sed -i "s|mysql://dbUser:dbPass@dbHost/dbName|mysql://${DB_USER}:${DB_PASS}@${DB_HOST}:3306/${DB_NAME}|" /root/.cv.json 2>/dev/null || true
}

wait_for_db
is_installed || install_civicrm
ensure_test_db_dsn

log "app-test ready — attach with 'docker compose exec app-test bash'"
exec sleep infinity
